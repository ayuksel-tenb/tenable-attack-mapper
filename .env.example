# Copy to .env and fill in. Never commit the real .env (see .gitignore).
# For a quick local test, copy .env_test instead — it's ready as-is.

# --- Tenable Security Center ---
TSC_URL=https://securitycenter.local
TSC_ACCESS_KEY=your-access-key
TSC_SECRET_KEY=your-secret-key
TSC_VERIFY_SSL=false

# --- Semantic mapping (hosted LLM API) ---
# Provider: "anthropic" (default) or "gemini".
TASC_SEMANTIC_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...            # required for the anthropic backend
ANTHROPIC_MODEL=claude-haiku-4-5        # haiku = fast
TASC_SEMANTIC_WORKERS=20                # parallel calls — higher = faster

# Gemini alternative (TASC_SEMANTIC_BACKEND=gemini; pip install -e '.[gemini]'):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Mapping behaviour (optional) ---
# TASC_CONFIDENCE_THRESHOLD=0.5      # below this -> flagged needs-review
# TASC_SEMANTIC_NO_CVE=false         # also map no-CVE compliance findings
# TASC_USE_NVD=false                 # live NVD CVE->CWE lookup for misses
# NVD_API_KEY=                       # higher NVD rate limits
