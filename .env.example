# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# --- Tenable Security Center (Tenable.sc) ---
# URL of your Security Center console.
TASC_SC_URL=https://localhost:8443/
# API keys generated in Security Center (User > API Keys). Never hard-code these.
TASC_SC_ACCESS_KEY=your-access-key
TASC_SC_SECRET_KEY=your-secret-key
# Set true only if your SC console uses a trusted/verifiable certificate.
TASC_SC_VERIFY_SSL=false

# --- Anthropic (semantic fallback) ---
# Optional. Without it, the tool runs deterministic-chain-only.
ANTHROPIC_API_KEY=sk-ant-...
# Override the semantic model (default: claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Mapping behaviour ---
# Mappings below this confidence are flagged "needs-review" (default 0.5).
# TASC_CONFIDENCE_THRESHOLD=0.5
# Set false to disable the semantic fallback entirely.
# TASC_ENABLE_SEMANTIC=true
# Set true to attempt a live NVD CVE->CWE lookup (falls back to the seed table).
# TASC_USE_NVD=false
# Override the reference-table directory.
# TASC_DATA_DIR=/path/to/data
