# Test config — copy to .env and you're ready (no Anthropic key needed):
#   cp .env_test .env
#
# These point at a LOCAL throwaway Security Center (localhost) — safe to ship as a
# template. Never put real/production keys in this file.

# --- Tenable Security Center ---
TSC_URL=https://localhost:8443/
TSC_ACCESS_KEY=700631c2899e4d8fa25fd88001cc6fc3
TSC_SECRET_KEY=8e358f1cbfbb4dee9ec144f5513286f3
TSC_VERIFY_SSL=false

# --- Semantic mapping (fast, on your Claude Code subscription) ---
# "claude" = local `claude` CLI, billed to your Claude Code subscription
#            (no per-token API cost, no API key). Requires Claude Code installed.
# "api"    = Anthropic API (set ANTHROPIC_API_KEY; pay per token).
TASC_SEMANTIC_BACKEND=claude
TASC_CLAUDE_MODEL=claude-haiku-4-5     # haiku = fast
TASC_SEMANTIC_WORKERS=20               # parallel calls — higher = faster

# Only needed if you switch to the paid API backend (TASC_SEMANTIC_BACKEND=api):
# ANTHROPIC_API_KEY=
