# Test config — copy to .env and you're ready (no Anthropic key needed):
#   cp .env_test .env
#
# These point at a LOCAL throwaway Security Center (localhost) — safe to ship as a
# template. Never put real/production keys in this file.

# --- Tenable Security Center ---
TSC_URL=https://localhost:8443/
TSC_ACCESS_KEY=700631c2899e4d8fa25fd88001cc6fc3
TSC_SECRET_KEY=8e358f1cbfbb4dee9ec144f5513286f3
TSC_VERIFY_SSL=false

# --- Semantic mapping (hosted LLM API) ---
# Provider: "anthropic" (default) or "gemini". Add the matching API key below.
TASC_SEMANTIC_BACKEND=anthropic
ANTHROPIC_API_KEY=                      # required for the anthropic backend
ANTHROPIC_MODEL=claude-haiku-4-5        # haiku = fast
TASC_SEMANTIC_WORKERS=8                 # parallel calls — higher = faster

# Gemini alternative (TASC_SEMANTIC_BACKEND=gemini):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
