# Test config — copy to .env and add your Anthropic key, then you're ready:
#   cp .env_test .env      # then set ANTHROPIC_API_KEY below
#
# These point at a LOCAL throwaway Security Center (localhost) — safe to ship as a
# template. Never put real/production keys in this file.

# --- Tenable Security Center ---
TSC_URL=https://localhost:8443/
TSC_ACCESS_KEY=700631c2899e4d8fa25fd88001cc6fc3
TSC_SECRET_KEY=8e358f1cbfbb4dee9ec144f5513286f3
TSC_VERIFY_SSL=false

# --- Anthropic (semantic mapping) ---
# Required for full coverage. Without it only the deterministic chain runs.
# A cheap model is plenty for bulk plugin->technique mapping:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
